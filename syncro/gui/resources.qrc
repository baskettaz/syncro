            <file alias="open">.\icons\open.png</file>
            <file alias="save">.\icons\save.png</file>
            <file alias="save_as">.\icons\save_as.png</file>
            <file alias="syncro">.\icons\syncro.png</file>
	</qresource>
</RCC>